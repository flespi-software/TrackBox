{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TrackBox",
  "version": "1.0.3",
  "identifier": "io.flespi.trackbox",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:8190",
    "beforeDevCommand": "node scripts/sync-app-name.mjs && node scripts/gen-licenses.mjs && quasar dev",
    "beforeBuildCommand": "node scripts/sync-app-name.mjs && node scripts/gen-licenses.mjs && quasar build"
  },
  "app": {
    "windows": [
      {
        "title": "TrackBox",
        "width": 1200,
        "height": 780,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/flespi-software/TrackBox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NDRDRDJFNkE0OEIxNzEKUldSeHNVaHFMczFFNVNSZmQ1WE1Fby8ybkJXUlRqVFJ2NE5EOCtQNFZSc21mcG1ka3kzUnZ4ZG4K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
